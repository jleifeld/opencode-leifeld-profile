{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "instructions": [
    "/Users/jannisleifeld/.config/opencode-profiles/leifeld/AGENTS.md",
    ".opencode/learnings/INDEX.md"
  ],
  "permission": {
    "lsp": "allow",
    "bash": {
      "ast-grep *": "allow",
      "sg *": "allow",
      "npx -y -p @ast-grep/cli ast-grep *": "allow",
      "npx -y -p @ast-grep/cli sg *": "allow"
    }
  },
  "lsp": {},
  "plugin": [
    "@ory/lumen-opencode"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT_TOKEN}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_KEY}"
      },
      "enabled": true
    }
  }
}
