{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "lsp": "allow",
    "grep": "ask",
    "playwright_*": "deny",
    "bash": {
      "*": "ask",
      "ast-grep *": "allow",
      "sg *": "allow",
      "npx -y -p @ast-grep/cli ast-grep *": "allow",
      "npx -y -p @ast-grep/cli sg *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch --list *": "allow",
      "git ls-files *": "allow",
      "rg *": "ask",
      "ls": "allow",
      "ls *": "allow",
      "find *": "ask",
      "cat *": "ask",
      "bun test": "allow",
      "bun test *": "allow",
      "npx ctx7@latest *": "allow",
      "tvly *": "allow",
      "gh auth status": "allow",
      "gh api rate_limit": "allow",
      "gh pr view * --json *": "allow",
      "gh pr checks * --json *": "allow",
      "gh run list * --json *": "allow",
      "gh run view * --json *": "allow",
      "gh run view * --log": "ask",
      "gh run view * --log-failed": "ask",
      "gh api *": "ask",
      "gh pr diff *": "ask",
      "gh *": "ask"
    }
  },
  "lsp": {},
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "semble": {
      "type": "local",
      "command": ["uvx", "--from", "semble[mcp]", "semble"]
    }
  }
}
