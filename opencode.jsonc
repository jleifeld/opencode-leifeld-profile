{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "lsp": "allow",
    "playwright_*": "deny",
    "bash": {
      "ast-grep *": "allow",
      "sg *": "allow",
      "npx -y -p @ast-grep/cli ast-grep *": "allow",
      "npx -y -p @ast-grep/cli sg *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch --list *": "allow",
      "git ls-files *": "allow",
      "rg *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "bun test": "allow",
      "bun test *": "allow",
      "npx ctx7@latest *": "allow",
      "tvly *": "allow",
      "gh *": "allow"
    }
  },
  "lsp": {},
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
